{
  "hooks": {
    "SessionStart": [{"matcher": "", "hooks": [{"type": "command",
      "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/coree inject --type session"}]}],
    "UserPromptSubmit": [{"matcher": "", "hooks": [{"type": "command",
      "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/coree inject --type prompt --budget 8000"}]}],
    "Stop": [{"matcher": "", "hooks": [{"type": "command",
      "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/coree inject --type stop"}]}],
    "PostCompact": [{"matcher": "", "hooks": [{"type": "command",
      "command": "node ${CLAUDE_PLUGIN_ROOT}/bin/coree inject --type compact"}]}]
  }
}
