{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "coree-inject-session",
            "type": "command",
            "command": "${extensionPath}/../shared/scripts/coree.cmd inject --type session"
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "*",
        "hooks": [
          {
            "name": "coree-inject-prompt",
            "type": "command",
            "command": "${extensionPath}/../shared/scripts/coree.cmd inject --type prompt --budget 8000"
          }
        ]
      }
    ]
  }
}
